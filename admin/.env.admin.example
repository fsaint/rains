# Admin tools secrets — copy to .env.admin and fill in values.
# .env.admin is gitignored; never commit real credentials.
#
# Token mint commands (see docs/ops/ADMIN_TOOLS.md for full instructions):
#   fly tokens create readonly --org personal --name "admin-tools-personal" --expiry 720h
#   fly tokens create readonly --org core-191 --name "admin-tools-core191" --expiry 720h
# Combine both tokens (comma-separated) as FLY_ADMIN_TOKEN below.
# Note: readonly tokens may not allow exec/restart — use deploy tokens for those if needed.

# Fly token — personal+core-191 scoped, READ + RESTART only (no destroy)
FLY_ADMIN_TOKEN=

# Reins backend URL
REINS_ADMIN_URL=https://app.helm.mom

# Bearer key — must match REINS_ADMIN_API_KEY Fly secret on agenthelm-core
REINS_ADMIN_API_KEY=

# Optional: override OpenClaw image for recover_agent.py
# OPENCLAW_IMAGE=registry.fly.io/reins-openclaw:<tag>

# Optional: platform MiniMax key (used by recover_agent.py for minimax agents without individual keys)
# MINIMAX_API_KEY=
