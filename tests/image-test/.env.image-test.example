# Image test environment — copy to .env.image-test and fill in values
# .env.image-test is gitignored (never commit it)

# Fly.io — test org (create with: fly orgs create reins-test)
FLY_TEST_ORG=reins-test
FLY_API_TOKEN=<token with access to reins-test org>

# Telethon (real Telegram user account for sending test messages)
TELETHON_API_ID=<from https://my.telegram.org/apps>
TELETHON_API_HASH=<from https://my.telegram.org/apps>
TELETHON_SESSION=~/.reins_imgtest_telethon.session
TELEGRAM_PHONE=+1xxxxxxxxxx

# Dedicated test bot token (create via @BotFather)
TEST_BOT_TOKEN=<bot token>
TEST_BOT_USERNAME=<bot username without @>

# LLM key for the test agent
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override the model used by the test agent
# OPENCLAW_MODEL=claude-sonnet-4-5

# Production apply (used by --promote to push images to production)
# OPENCLAW_APP defaults to agentx-openclaw — override if your prod app has a different name
# OPENCLAW_APP=agentx-openclaw
# REINS_BACKEND_APP — set to your backend Fly app name to auto-update HERMES_IMAGE on promote
# REINS_BACKEND_APP=reins-backend
