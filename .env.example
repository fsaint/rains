# Reins Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Server Configuration
# =============================================================================

# Port for the backend server (default: 3000)
REINS_PORT=3000

# Host to bind to (default: 0.0.0.0)
REINS_HOST=0.0.0.0

# PostgreSQL connection URL
DATABASE_URL=postgres://localhost:5432/reins

# Log level: debug, info, warn, error (default: info)
REINS_LOG_LEVEL=info

# Environment: development, production, test (default: development)
NODE_ENV=development

# =============================================================================
# Security
# =============================================================================

# Admin password for dashboard login (required)
REINS_ADMIN_PASSWORD=

# Session signing secret (min 32 chars; auto-generated default for dev)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REINS_SESSION_SECRET=

# 32-byte hex encryption key for credential storage (64 hex characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty in development to use a default key (NOT SECURE - dev only!)
REINS_ENCRYPTION_KEY=

# =============================================================================
# Dashboard Configuration
# =============================================================================

# Frontend dashboard URL (for OAuth redirects)
REINS_DASHBOARD_URL=http://localhost:5173

# =============================================================================
# Google OAuth (Gmail, Drive, Calendar)
# =============================================================================
#
# Setup instructions:
# 1. Go to https://console.cloud.google.com/
# 2. Create or select a project
# 3. Enable APIs: Gmail API, Drive API, Calendar API
# 4. Go to "APIs & Services" > "Credentials"
# 5. Create "OAuth 2.0 Client ID" (Web application type)
# 6. Add authorized redirect URI: http://localhost:3000/api/oauth/google/callback
# 7. Copy Client ID and Client Secret below

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# =============================================================================
# Brave Search API (Web Search)
# =============================================================================
#
# Get your API key at: https://brave.com/search/api/

BRAVE_API_KEY=

# =============================================================================
# Browser Server Configuration
# =============================================================================

# Maximum number of concurrent browser instances (default: 5)
BROWSER_MAX_INSTANCES=5

# Browser idle timeout in milliseconds (default: 300000 = 5 minutes)
BROWSER_IDLE_TIMEOUT=300000

# =============================================================================
# Agent Deployment (Fly.io / Docker)
# =============================================================================

# Provider: "fly" for Fly.io (production), "local" for Docker (development)
REINS_PROVIDER=fly

# Fly.io API token (required for Fly.io provider)
FLY_API_TOKEN=

# Fly.io organization slug
FLY_ORG=

# OpenClaw Docker image for deployed agents
# Leave blank to auto-resolve from OPENCLAW_APP's latest machine image
# Or set explicitly: registry.fly.io/reins-openclaw:deployment-<TAG>
OPENCLAW_IMAGE=

# Fly app name that holds the OpenClaw image (used when OPENCLAW_IMAGE is empty)
OPENCLAW_APP=agentx-openclaw

# Anthropic API key (passed to deployed agents)
ANTHROPIC_API_KEY=

# Public URL for this Reins instance (used in MCP config for deployed agents)
# Defaults to REINS_DASHBOARD_URL if not set
REINS_PUBLIC_URL=
