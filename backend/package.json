{
  "name": "@reins/backend",
  "version": "0.1.0",
  "description": "Reins backend - MCP proxy, policy engine, and API server",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^9.0.0",
    "@libsql/client": "^0.4.3",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@reins/servers": "*",
    "@reins/shared": "*",
    "@types/jsonwebtoken": "^9.0.10",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.29.3",
    "fastify": "^4.25.2",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.0.4",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "drizzle-kit": "^0.20.12",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "vitest": "^1.2.0"
  }
}
